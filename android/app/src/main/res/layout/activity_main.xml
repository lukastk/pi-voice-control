<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1a1a2e">

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Tiny invisible strip at the very top edge to receive long-press for
         changing the configured URL. WebView swallows long-press touches so
         we need a layer above it. Width is small + transparent so it doesn't
         interfere with normal use. -->
    <View
        android:id="@+id/url_long_press_target"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:background="@android:color/transparent"
        android:contentDescription="Long-press to change URL" />

    <!-- Connection-error overlay. Shown when the active target's page fails
         to load (server off / host unreachable) so the user is never stuck
         on a blank WebView. Covers the WebView and offers a way to switch
         targets or retry. Hidden by default; toggled from MainActivity. -->
    <LinearLayout
        android:id="@+id/connection_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:background="#1a1a2e"
        android:visibility="gone">

        <TextView
            android:id="@+id/connection_error_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#e0e0e0"
            android:textSize="16sp"
            android:text="Couldn't reach the selected target." />

        <Button
            android:id="@+id/connection_error_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Switch target" />

        <Button
            android:id="@+id/connection_error_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Retry" />

    </LinearLayout>

</FrameLayout>
